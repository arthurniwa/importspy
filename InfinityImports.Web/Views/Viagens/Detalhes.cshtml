@model InfinityImports.Core.Models.Viagem
@{
    ViewData["Title"] = "Detalhes da Viagem";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Viagem — @Model.DataPrevista.ToString("dd/MM/yyyy")</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">Voltar</a>
</div>
@if (Model.Status != InfinityImports.Core.Models.StatusViagem.Concluida)
{
    <a asp-action="EntradaEstoque" asp-route-id="@Model.Id" class="btn btn-primary">
        Dar entrada no estoque
    </a>
}

<h5 class="mb-3">Lista de Encomendas</h5>

@if (!Model.Encomendas.Any())
{
    <p class="text-white-50">Nenhuma encomenda vinculada a esta viagem.</p>
}
else
{
    <table class="table table-dark table-hover">
        <thead>
            <tr>
                <th>Produto</th>
                <th>Cliente</th>
                <th>Qtd</th>
                <th>Preço</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var e in Model.Encomendas)
            {
                <tr>
                    <td>@(e.Produto?.Nome ?? e.NomeProdutoSnapshot ?? "—")</td>
                    <td>@e.ClienteNome</td>
                    <td>@e.Quantidade</td>
                    <td>R$ @e.PrecoNoMomento.ToString("F2")</td>
                    <td>@e.Status</td>
                </tr>
            }
        </tbody>
    </table>
}
