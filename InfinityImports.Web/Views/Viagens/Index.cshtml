@model IEnumerable<InfinityImports.Core.Models.Viagem>
@{
    ViewData["Title"] = "Viagens";
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
    <h2 class="ii-page-title mb-0">Viagens</h2>
    <a asp-action="Create" class="btn-ii btn-ii-primary btn-ii-sm">
        <i class="bi bi-plus-lg"></i> Nova Viagem
    </a>
</div>

<div class="ii-card p-0">
    <table class="ii-table">
        <thead>
            <tr>
                <th>Data Prevista</th>
                <th>Retorno</th>
                <th>Status</th>
                <th>Encomendas</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var v in Model)
            {
                <tr>
                    <td>@v.DataPrevista.ToString("dd/MM/yyyy")</td>
                    <td>@(v.DataRetorno.HasValue ? v.DataRetorno.Value.ToString("dd/MM/yyyy") : "—")</td>
                    <td>
                        <span class="ii-badge @(v.Status == InfinityImports.Core.Models.StatusViagem.Planejada ? "ii-badge-blue" :
                                             v.Status == InfinityImports.Core.Models.StatusViagem.Concluida ? "ii-badge-green" : "ii-badge-gray")">
                            @v.Status
                        </span>
                    </td>
                    <td>@v.Encomendas.Count</td>
                    <td>
                        <div class="d-flex gap-1 flex-wrap">
                            <a asp-action="Detalhes" asp-route-id="@v.Id" class="btn-ii btn-ii-ghost btn-ii-sm">Ver</a>
                            <a asp-action="Edit" asp-route-id="@v.Id" class="btn-ii btn-ii-ghost btn-ii-sm">Editar</a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>