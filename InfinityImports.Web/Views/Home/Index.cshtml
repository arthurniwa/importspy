@model IEnumerable<InfinityImports.Core.Models.Produto>
@{
    ViewData["Title"] = "Catálogo";
    Layout = "~/Views/Shared/_LayoutPublico.cshtml";
    var produtos = Model.ToList();
    var featured = produtos.Where(p => p.Estoque > 0).Take(3).ToList();
    var semFiltro = ViewBag.CategoriaAtual == null;
    var categorias = ViewBag.Categorias as IEnumerable<InfinityImports.Core.Models.Categoria> ?? Enumerable.Empty<InfinityImports.Core.Models.Categoria>();
}

@* ── Hero (só sem filtro de categoria) ── *@
@if (semFiltro)
{
    <section class="hero-sp">
        <div class="spot"></div>
        <div class="spot2"></div>
        <div class="wrap">
            <div class="inner">
                <div class="chip">
                    <i></i>
                    <span>Importados originais · entrega nacional</span>
                </div>
                <h1>O melhor dos <span class="grad-txt">importados</span><br>num só lugar.</h1>
                <p class="lead">Perfumaria árabe, skincare coreano e eletrônicos. Selecionados, lacrados e prontos pra enviar pra todo o Brasil.</p>
                <div class="cta-row">
                    <a href="#catalogo" class="pub-btn pub-btn-primary">
                        Explorar catálogo
                        <i class="bi bi-arrow-right" style="font-size:15px;"></i>
                    </a>
                    <a asp-controller="Cliente" asp-action="Registrar" class="pub-btn pub-btn-ghost">
                        Criar minha conta
                    </a>
                </div>

                @if (featured.Any())
                {
                    <div class="hero-strip">
                        @foreach (var p in featured)
                        {
                            <a asp-action="Produto" asp-route-id="@p.Id" class="fcard">
                                <div class="fimg @(p.Foto == null ? "ph" : "")">
                                    @if (p.Foto != null)
                                    {
                                        <img src="@p.Foto" alt="@p.Nome" />
                                    }
                                    else
                                    {
                                        <span>@p.Nome</span>
                                    }
                                </div>
                                <div class="ft">
                                    <small>@p.Categoria.Nome</small>
                                    <b>@p.Nome</b>
                                    <span class="pr">R$ @p.PrecoFinal.ToString("F2")</span>
                                </div>
                            </a>
                        }
                    </div>
                }
            </div>
        </div>
    </section>
}

@* ── Category pills ── *@
<div class="catrow" id="catalogo">
    <div class="wrap">
        <a asp-action="Index" class="pill @(semFiltro ? "active" : "")">
            <i></i>Todos
        </a>
        @foreach (var cat in categorias)
        {
            <a asp-action="Index" asp-route-categoriaId="@cat.Id"
               class="pill @(ViewBag.CategoriaAtual == cat.Id ? "active" : "")">
                <i></i>@cat.Nome
            </a>
        }
    </div>
</div>

@* ── Product grid ── *@
<section class="sec">
    <div class="wrap">
        <div class="sec-head">
            <div>
                @if (!semFiltro && categorias.Any())
                {
                    var catAtual = categorias.FirstOrDefault(c => c.Id == (int?)ViewBag.CategoriaAtual);
                    <span class="mono">@(catAtual?.Nome ?? "Filtrado")</span>
                }
                else
                {
                    <span class="mono">Catálogo completo</span>
                }
                <h2>@(produtos.Count) produto@(produtos.Count != 1 ? "s" : "") disponíve@(produtos.Count != 1 ? "is" : "l")</h2>
            </div>
        </div>

        @if (!produtos.Any())
        {
            <p style="color:var(--txt-soft); text-align:center; padding:40px 0;">Nenhum produto disponível no momento.</p>
        }
        else
        {
            <div class="pgrid">
                @foreach (var p in produtos)
                {
                    <a asp-action="Produto" asp-route-id="@p.Id" style="text-decoration:none;">
                        <div class="card">
                            <div class="pimg @(p.Foto == null ? "ph" : "")">
                                @if (p.Foto != null)
                                {
                                    <img src="@p.Foto" alt="@p.Nome" />
                                }
                                else
                                {
                                    <span>@p.Nome</span>
                                }
                                @if (p.Estoque > 0)
                                {
                                    <span class="badge-top">Em estoque</span>
                                }
                            </div>
                            <div class="pbody">
                                <span class="tagline">@p.Categoria.Nome</span>
                                <h4>@p.Nome</h4>
                                <div class="pbottom">
                                    <span class="price">
                                        R$ @p.PrecoFinal.ToString("F2")
                                    </span>
                                    <span class="add-btn">+</span>
                                </div>
                            </div>
                        </div>
                    </a>
                }
            </div>
        }
    </div>
</section>

@* ── Chrome band ── *@
@if (semFiltro)
{
    <section class="chrome-band">
        <div class="wrap">
        <div class="inner">
            <span class="mono" style="color:var(--cyan);display:block;margin-bottom:14px;">Direto do Paraguai</span>
            <h2 class="chrome-txt">Produtos originais<br>por uma fração do preço.</h2>
            <p>Importação direta, sempre lacrados e com nota fiscal. Entregamos para todo o Brasil.</p>
            <a asp-controller="Cliente" asp-action="Registrar" class="pub-btn pub-btn-primary">
                Criar minha conta →
            </a>
        </div>
        </div>
    </section>

    <section class="wrap">
        <div class="trust-grid">
            <div class="ti">
                <div class="ic">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7">
                        <path d="M12 2 4 5v6c0 5 3.5 8 8 11 4.5-3 8-6 8-11V5z"></path>
                        <path d="m9 12 2 2 4-4"></path>
                    </svg>
                </div>
                <b>100% Original</b>
                <p>Importação direta e sempre lacrado</p>
            </div>
            <div class="ti">
                <div class="ic">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7">
                        <rect x="1" y="6" width="15" height="11" rx="1"></rect>
                        <path d="M16 9h4l3 3v5h-7z"></path>
                        <circle cx="6" cy="18" r="1.5"></circle>
                        <circle cx="18" cy="18" r="1.5"></circle>
                    </svg>
                </div>
                <b>Envio nacional</b>
                <p>Para todo o Brasil com rastreio</p>
            </div>
            <div class="ti">
                <div class="ic">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7">
                        <rect x="2" y="5" width="20" height="14" rx="2"></rect>
                        <path d="M2 10h20"></path>
                    </svg>
                </div>
                <b>Até 12x</b>
                <p>No cartão, sem complicação</p>
            </div>
            <div class="ti">
                <div class="ic">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7">
                        <path d="M21 11.5a8.4 8.4 0 0 1-9 8.4L3 21l1.1-9A8.4 8.4 0 1 1 21 11.5z"></path>
                    </svg>
                </div>
                <b>Atendimento</b>
                <p>Suporte humano no WhatsApp</p>
            </div>
        </div>
    </section>
}
