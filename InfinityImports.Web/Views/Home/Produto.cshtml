@model InfinityImports.Core.Models.Produto
@{
    ViewData["Title"] = Model.Nome;
    Layout = "~/Views/Shared/_LayoutPublico.cshtml";
}

<div class="container py-5" style="max-width:720px;">
    <a asp-action="Index" class="text-white-50 small d-block mb-4">← Voltar ao catálogo</a>

    <div class="row g-4">
        <div class="col-md-5">
            @if (Model.Foto != null)
            {
                <img src="@Model.Foto" class="img-fluid rounded" style="object-fit:cover; width:100%;" />
            }
            else
            {
                <div style="height:280px; background:#1a1a1a; border-radius:8px; display:flex; align-items:center; justify-content:center;">
                    <span class="text-white-50">Sem foto</span>
                </div>
            }
        </div>
        <div class="col-md-7">
            <p class="text-white-50 small mb-1">@Model.Categoria.Nome</p>
            <h2 class="text-white">@Model.Nome</h2>
            <h3 style="color:#1A3FD4;">R$ @Model.PrecoFinal.ToString("F2")</h3>

            @if (ViewBag.ProximaViagem != null)
            {
                <p class="text-white-50 mt-3 small">
                    Próxima viagem ao Paraguai:
                    <strong class="text-white">@((DateTime)ViewBag.ProximaViagem.DataPrevista).ToString("dd/MM/yyyy")</strong>
                </p>
            }

            <a asp-action="Encomendar" asp-route-produtoId="@Model.Id"
               class="btn btn-primary mt-3 px-4">Encomendar</a>
        </div>
    </div>
</div>
