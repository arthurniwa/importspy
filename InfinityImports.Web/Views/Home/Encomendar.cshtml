@{
    ViewData["Title"] = "Encomendar";
    Layout = "~/Views/Shared/_LayoutPublico.cshtml";
    var produto = ViewBag.Produto as InfinityImports.Core.Models.Produto;
    var viagem = ViewBag.ProximaViagem as InfinityImports.Core.Models.Viagem;
}

<div class="encomenda-wrap">
    <div class="encomenda-header">
        <a asp-action="Produto" asp-route-id="@produto!.Id" class="back-link">← Voltar</a>
        <h2 style="font-family:var(--grot);font-weight:700;font-size:28px;margin:12px 0 4px;">Fazer encomenda</h2>
        <p style="color:var(--txt-soft);font-size:14px;">Preencha os dados para registrar seu pedido</p>
    </div>

    <div class="encomenda-card">
        <div class="ec-img @(produto.Foto == null ? "ph" : "")">
            @if (produto.Foto != null)
            {
                <img src="@produto.Foto" alt="@produto.Nome" />
            }
            else
            {
                <span style="font-size:9px;color:var(--txt-dim);font-family:var(--grot);letter-spacing:.1em;text-transform:uppercase;padding:8px;text-align:center;">SEM FOTO</span>
            }
        </div>
        <div class="ec-info">
            <small>@produto.Categoria.Nome</small>
            <b>@produto.Nome</b>
            <span>R$ @produto.PrecoFinal.ToString("F2")</span>
        </div>
    </div>

    @if (viagem != null)
    {
        <div class="info-box">
            <i class="bi bi-airplane me-2"></i>
            Próxima viagem ao Paraguai: <strong>@viagem.DataPrevista.ToString("dd/MM/yyyy")</strong>
        </div>
    }

    <form asp-action="Encomendar" method="post">
        <input type="hidden" name="ProdutoId" value="@produto.Id" />
        <input type="hidden" name="ViagemId" value="@viagem?.Id" />

        <div class="pub-field">
            <label class="pub-label">Seu nome</label>
            <input name="ClienteNome" class="pub-input" placeholder="Nome completo" required />
        </div>
        <div class="pub-field">
            <label class="pub-label">WhatsApp</label>
            <input name="ClienteTelefone" class="pub-input" placeholder="(00) 00000-0000" required />
        </div>
        <div class="pub-field">
            <label class="pub-label">Quantidade</label>
            <input name="Quantidade" type="number" min="1" value="1" class="pub-input" required />
        </div>
        <div class="pub-field">
            <label class="pub-label">Observações <span style="color:var(--txt-dim);font-weight:400;">(opcional)</span></label>
            <textarea name="Observacoes" class="pub-input" placeholder="Cor, tamanho, ou qualquer detalhe..."></textarea>
        </div>

        <button type="submit" class="pub-btn pub-btn-primary w-100 mt-2" style="width:100%;justify-content:center;">
            Confirmar Encomenda
        </button>
    </form>
</div>
