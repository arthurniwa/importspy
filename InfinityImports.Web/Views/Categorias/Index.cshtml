@model IEnumerable<InfinityImports.Core.Models.Categoria>
@{
    ViewData["Title"] = "Categorias";
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
    <h2 class="ii-page-title mb-0">Categorias</h2>
    <a asp-action="Create" class="btn-ii btn-ii-primary btn-ii-sm">
        <i class="bi bi-plus-lg"></i> Nova Categoria
    </a>
</div>

<div class="ii-card p-0">
    <table class="ii-table">
        <thead>
            <tr>
                <th>Nome</th>
                <th>Produtos</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var c in Model)
            {
                <tr>
                    <td>@c.Nome</td>
                    <td>@c.Produtos.Count</td>
                    <td>
                        <div class="d-flex gap-1 flex-wrap">
                            <a asp-action="Edit" asp-route-id="@c.Id" class="btn-ii btn-ii-ghost btn-ii-sm">Editar</a>
                            <form asp-action="Delete" asp-route-id="@c.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('Excluir categoria @c.Nome?')">
                                <button type="submit" class="btn-ii btn-ii-danger btn-ii-sm">Excluir</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>