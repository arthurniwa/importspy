@model IEnumerable<InfinityImports.Core.Models.Categoria>
@{
    ViewData["Title"] = "Categorias";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Categorias</h2>
    <a asp-action="Create" class="btn btn-primary">+ Nova Categoria</a>
</div>

<table class="table table-dark table-hover">
    <thead>
        <tr>
            <th>Nome</th>
            <th>Produtos</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var c in Model)
        {
            <tr>
                <td>@c.Nome</td>
                <td>@c.Produtos.Count</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@c.Id" class="btn btn-sm btn-outline-light">Editar</a>
                    <form asp-action="Delete" asp-route-id="@c.Id" method="post" class="d-inline"
                          onsubmit="return confirm('Excluir categoria @c.Nome?')">
                        <button type="submit" class="btn btn-sm btn-outline-danger">Excluir</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>