@model IEnumerable<InfinityImports.Core.Models.Encomenda>
@{
    ViewData["Title"] = "Encomendas";
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
    <h2 class="ii-page-title mb-0">Encomendas</h2>
    <a asp-action="Create" class="btn-ii btn-ii-primary btn-ii-sm">
        <i class="bi bi-plus-lg"></i> Nova Encomenda
    </a>
</div>

<div class="ii-card p-0">
    <table class="ii-table">
        <thead>
            <tr>
                <th>Data</th>
                <th>Cliente</th>
                <th>Produto</th>
                <th>Qtd</th>
                <th>Preço</th>
                <th>Viagem</th>
                <th>Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var e in Model)
            {
                <tr>
                    <td>@e.DataEncomenda.ToLocalTime().ToString("dd/MM/yyyy")</td>
                    <td>@e.ClienteNome</td>
                    <td>@(e.Produto?.Nome ?? e.NomeProdutoSnapshot ?? "—")</td>
                    <td>@e.Quantidade</td>
                    <td>R$ @e.PrecoNoMomento.ToString("F2")</td>
                    <td>@(e.Viagem != null ? e.Viagem.DataPrevista.ToString("dd/MM/yyyy") : "—")</td>
                    <td>
                        <span class="ii-badge @(e.Status == InfinityImports.Core.Models.StatusEncomenda.Pendente ? "ii-badge-yellow" :
                                             e.Status == InfinityImports.Core.Models.StatusEncomenda.Entregue ? "ii-badge-green" :
                                             e.Status == InfinityImports.Core.Models.StatusEncomenda.Cancelada ? "ii-badge-red" : "ii-badge-blue")">
                            @e.Status
                        </span>
                    </td>
                    <td>
                        <form asp-action="AtualizarStatus" method="post" class="d-flex gap-1">
                            <input type="hidden" name="id" value="@e.Id" />
                            <select name="status" class="ii-input" style="padding:0.35rem 0.6rem; font-size:0.78rem; min-width:120px;"
                                    asp-items="Html.GetEnumSelectList<InfinityImports.Core.Models.StatusEncomenda>()"
                                    onchange="this.form.submit()">
                            </select>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>