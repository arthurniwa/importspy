@model IEnumerable<InfinityImports.Core.Models.Encomenda>
@{
    ViewData["Title"] = "Minhas Encomendas";
    Layout = "~/Views/Shared/_LayoutPublico.cshtml";
}

<div class="container py-5">
    <h2 class="text-white mb-4">Minhas Encomendas</h2>

    @if (!Model.Any())
    {
        <p class="text-white-50">Você ainda não fez nenhuma encomenda.</p>
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary mt-2">Ver produtos</a>
    }
    else
    {
        <table class="table table-dark table-hover">
            <thead>
                <tr>
                    <th>Data</th>
                    <th>Produto</th>
                    <th>Qtd</th>
                    <th>Valor</th>
                    <th>Viagem prevista</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var e in Model)
                {
                    <tr>
                        <td>@e.DataEncomenda.ToLocalTime().ToString("dd/MM/yyyy")</td>
                        <td>@e.Produto.Nome</td>
                        <td>@e.Quantidade</td>
                        <td>R$ @e.PrecoNoMomento.ToString("F2")</td>
                        <td>@(e.Viagem != null ? e.Viagem.DataPrevista.ToString("dd/MM/yyyy") : "—")</td>
                        <td>
                            <span class="badge @(e.Status == InfinityImports.Core.Models.StatusEncomenda.Entregue ? "bg-success" :
                                                 e.Status == InfinityImports.Core.Models.StatusEncomenda.Cancelada ? "bg-danger" :
                                                 e.Status == InfinityImports.Core.Models.StatusEncomenda.Chegou ? "bg-info" : "bg-primary")">
                                @e.Status
                            </span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
