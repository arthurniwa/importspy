<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Infinity Imports</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <style>
        body { background: #000; color: #fff; }
        .navbar { background: #0a0a0a !important; border-bottom: 1px solid #1A3FD4; }
        .navbar-brand { color: #1A3FD4 !important; font-weight: bold; }
        .nav-link { color: #ccc !important; }
        .nav-link:hover { color: #1A3FD4 !important; }
        .btn-primary { background: #1A3FD4; border-color: #1A3FD4; }
        .btn-primary:hover { background: #1535b0; border-color: #1535b0; }
        .card { background: #111; border-color: #222; }
        .table-dark { --bs-table-bg: #111; }
        footer { border-top: 1px solid #222 !important; color: #555; }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm mb-4">
            <div class="container">
                <a class="navbar-brand" asp-controller="Admin" asp-action="Dashboard">
                    Infinity Imports
                </a>
                <div class="collapse navbar-collapse">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Admin" asp-action="Dashboard">Dashboard</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Produtos" asp-action="Index">Produtos</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Viagens" asp-action="Index">Viagens</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Encomendas" asp-action="Index">Encomendas</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Categorias" asp-action="Index">Categorias</a>
                        </li>
                    </ul>
                    <form asp-controller="Admin" asp-action="Logout" method="post" class="d-inline">
                        <button type="submit" class="btn btn-sm btn-outline-secondary">Sair</button>
                    </form>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main class="pb-4">
            @RenderBody()
        </main>
    </div>

    <footer class="py-3 mt-4">
        <div class="container text-center small">
            &copy; 2026 Infinity Imports
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>