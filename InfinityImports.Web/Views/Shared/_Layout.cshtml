<!DOCTYPE html>
<html lang="pt-BR" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Infinity Imports</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

<!-- Overlay mobile -->
<div class="ii-overlay" id="overlay" onclick="closeSidebar()"></div>

<!-- Topbar mobile -->
<div class="ii-topbar">
    <button class="ii-topbar-toggle" onclick="openSidebar()">
        <i class="bi bi-list"></i>
    </button>
    <span class="brand-name">INFINITY IMPORTS</span>
    <div style="width:32px;"></div>
</div>

<!-- Sidebar -->
<aside class="ii-sidebar" id="sidebar">
    <div class="ii-sidebar-brand">
        <div class="brand-name">INFINITY IMPORTS</div>
        <div class="brand-sub">Painel Administrativo</div>
    </div>

    <ul class="ii-nav">
        <li class="ii-nav-section">Geral</li>
        <li>
            <a asp-controller="Admin" asp-action="Dashboard"
               class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" && ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" ? "active" : "")">
                <i class="bi bi-speedometer2"></i> Dashboard
            </a>
        </li>

        <li class="ii-nav-section">Catálogo</li>
        <li>
            <a asp-controller="Produtos" asp-action="Index"
               class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Produtos" ? "active" : "")">
                <i class="bi bi-box-seam"></i> Produtos
            </a>
        </li>
        <li>
            <a asp-controller="Categorias" asp-action="Index"
               class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Categorias" ? "active" : "")">
                <i class="bi bi-tags"></i> Categorias
            </a>
        </li>

        <li class="ii-nav-section">Operações</li>
        <li>
            <a asp-controller="Encomendas" asp-action="Index"
               class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Encomendas" ? "active" : "")">
                <i class="bi bi-bag"></i> Encomendas
            </a>
        </li>
        <li>
            <a asp-controller="SolicitacoesEspeciais" asp-action="Admin"
               class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "SolicitacoesEspeciais" ? "active" : "")">
                <i class="bi bi-chat-square-quote"></i> Solicitações
            </a>
        </li>
        <li>
            <a asp-controller="Viagens" asp-action="Index"
               class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Viagens" ? "active" : "")">
                <i class="bi bi-airplane"></i> Viagens
            </a>
        </li>

        <li class="ii-nav-section">Loja</li>
        <li>
            <a asp-controller="Home" asp-action="Index" target="_blank">
                <i class="bi bi-shop"></i> Ver loja pública
            </a>
        </li>
    </ul>

    <div class="ii-sidebar-footer">
        <div class="ii-user-row">
            <div class="ii-avatar">A</div>
            <div>
                <div class="ii-user-name">Administrador</div>
                <div class="ii-user-role">Admin</div>
            </div>
        </div>

        <button class="theme-toggle" onclick="toggleTheme()" title="Alternar tema">
            <span id="theme-label"><i class="bi bi-moon"></i> Modo escuro</span>
            <div class="toggle-track"></div>
        </button>

        <form asp-controller="Admin" asp-action="Logout" method="post">
            <button type="submit" class="ii-logout-btn">
                <i class="bi bi-box-arrow-left"></i> Sair
            </button>
        </form>
    </div>
</aside>

<!-- Conteúdo principal -->
<main class="ii-main">
    @RenderBody()
</main>

<script>
    // ── Tema ─────────────────────────────────────────
    const html = document.documentElement;
    const label = document.getElementById('theme-label');

    const saved = localStorage.getItem('ii-theme') || 'dark';
    applyTheme(saved);

    function applyTheme(theme) {
        html.setAttribute('data-theme', theme);
        localStorage.setItem('ii-theme', theme);
        if (label) {
            label.innerHTML = theme === 'dark'
                ? '<i class="bi bi-moon"></i> Modo escuro'
                : '<i class="bi bi-sun"></i> Modo claro';
        }
    }

    function toggleTheme() {
        const current = html.getAttribute('data-theme');
        applyTheme(current === 'dark' ? 'light' : 'dark');
    }

    // ── Sidebar mobile ────────────────────────────────
    function openSidebar() {
        document.getElementById('sidebar').classList.add('open');
        document.getElementById('overlay').classList.add('active');
    }

    function closeSidebar() {
        document.getElementById('sidebar').classList.remove('open');
        document.getElementById('overlay').classList.remove('active');
    }
</script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
