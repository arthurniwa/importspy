<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Infinity Imports</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <style>
        body { background: #000; color: #fff; }
        .navbar { background: #0a0a0a !important; border-bottom: 1px solid #1A3FD4; }
        .navbar-brand { color: #1A3FD4 !important; font-weight: bold; letter-spacing: 1px; }
        .btn-primary { background: #1A3FD4; border-color: #1A3FD4; }
        .btn-primary:hover { background: #1535b0; border-color: #1535b0; }
        .card { background: #111; border-color: #222; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-sm mb-2">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">INFINITY IMPORTS</a>
            <div class="collapse navbar-collapse justify-content-end">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a asp-controller="Cliente" asp-action="MinhasEncomendas"
                       class="btn btn-sm btn-outline-secondary me-2">Minhas Encomendas</a>
                    <form asp-controller="Cliente" asp-action="Logout" method="post" class="d-inline">
                        <button type="submit" class="btn btn-sm btn-outline-secondary">Sair</button>
                    </form>
                }
                else
                {
                    <a asp-controller="Cliente" asp-action="Login"
                       class="btn btn-sm btn-outline-secondary me-2">Entrar</a>
                    <a asp-controller="Cliente" asp-action="Registrar"
                       class="btn btn-sm btn-primary">Criar conta</a>
                }
            </div>
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
