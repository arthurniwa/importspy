@{
    ViewData["Title"] = "Dashboard";
}

<h1 class="ii-page-title">Dashboard</h1>

<div class="row g-3 mb-4">
    <div class="col-12 col-md-4">
        <div class="ii-hero-card">
            <div class="ii-card-title">Encomendas pendentes</div>
            <div class="ii-card-value">@ViewBag.TotalEncomendas</div>
            <div class="ii-card-sub">Aguardando confirmação ou em viagem</div>
        </div>
    </div>
    <div class="col-6 col-md-4">
        <div class="ii-card">
            <div class="ii-card-title">Produtos ativos</div>
            <div class="ii-card-value">@ViewBag.TotalProdutos</div>
            <div class="ii-card-sub">No catálogo público</div>
        </div>
    </div>
    <div class="col-6 col-md-4">
        <div class="ii-card">
            <div class="ii-card-title">Próxima viagem</div>
            @if (ViewBag.ProximaViagem != null)
            {
                <div class="ii-card-value" style="font-size:1.25rem;">
                    @((DateTime)ViewBag.ProximaViagem.DataPrevista).ToString("dd/MM/yyyy")
                </div>
                <div class="ii-card-sub">Viagem ao Paraguai</div>
            }
            else
            {
                <div class="ii-card-value" style="font-size:1rem; color:var(--text-3);">—</div>
                <div class="ii-card-sub">Nenhuma agendada</div>
            }
        </div>
    </div>
</div>

<div class="ii-card mb-4">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
        <div>
            <div class="ii-card-title">Cotação do dólar</div>
            <div class="ii-card-value" style="font-size:1.5rem;">
                R$ @(ViewBag.CotacaoAtual != null ? ((decimal)ViewBag.CotacaoAtual).ToString("F4") : "—")
            </div>
            <div class="ii-card-sub">Atualizada diariamente às 08:00</div>
        </div>
        <form asp-action="AtualizarCotacao" method="post">
            <button type="submit" class="btn-ii btn-ii-ghost">
                <i class="bi bi-arrow-clockwise"></i> Atualizar agora
            </button>
        </form>
    </div>
</div>

<div class="row g-3">
    <div class="col-12 col-lg-5">
        <div class="ii-card">
            <div class="ii-card-title mb-3">Encomendas por status</div>
            <div style="position:relative; height:240px;">
                <canvas id="chartStatus"></canvas>
            </div>
        </div>
    </div>
    <div class="col-12 col-lg-7">
        <div class="ii-card">
            <div class="ii-card-title mb-3">Evolução da cotação (últimos 30 dias)</div>
            <div style="position:relative; height:240px;">
                <canvas id="chartCotacao"></canvas>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
    const isDark = () => document.documentElement.getAttribute('data-theme') !== 'light';
    const gridColor = () => isDark() ? 'rgba(255,255,255,0.06)' : 'rgba(0,0,0,0.06)';
    const tickColor = () => isDark() ? '#a0a0a0' : '#6b7280';

    const statusLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.StatusLabels as string[] ?? Array.Empty<string>()));
    const statusValues = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.StatusValues as int[] ?? Array.Empty<int>()));
    const cotacaoLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.CotacaoLabels as string[] ?? Array.Empty<string>()));
    const cotacaoValues = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.CotacaoValues as double[] ?? Array.Empty<double>()));

    new Chart(document.getElementById('chartStatus'), {
        type: 'doughnut',
        data: {
            labels: statusLabels,
            datasets: [{
                data: statusValues,
                backgroundColor: ['#f59e0b','#1A3FD4','#06b6d4','#10b981','#6b7280','#ef4444'],
                borderWidth: 0,
                hoverOffset: 6
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            cutout: '68%',
            plugins: {
                legend: {
                    position: 'bottom',
                    labels: { color: tickColor(), font: { family: 'Inter', size: 11 }, usePointStyle: true, padding: 16 }
                }
            }
        }
    });

    new Chart(document.getElementById('chartCotacao'), {
        type: 'line',
        data: {
            labels: cotacaoLabels,
            datasets: [{
                label: 'USD → BRL',
                data: cotacaoValues,
                borderColor: '#1A3FD4',
                backgroundColor: 'rgba(26,63,212,0.1)',
                fill: true,
                tension: 0.3,
                pointRadius: 3,
                pointBackgroundColor: '#1A3FD4'
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
                x: { grid: { color: gridColor() }, ticks: { color: tickColor(), font: { family: 'Inter', size: 11 } } },
                y: { beginAtZero: false, grid: { color: gridColor() }, ticks: { color: tickColor(), font: { family: 'Inter', size: 11 } } }
            }
        }
    });
</script>
}
