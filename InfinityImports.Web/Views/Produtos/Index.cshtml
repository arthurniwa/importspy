@model IEnumerable<InfinityImports.Core.Models.Produto>
@{
    ViewData["Title"] = "Produtos";
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
    <h2 class="ii-page-title mb-0">Produtos</h2>
    <div class="d-flex align-items-center gap-2 flex-wrap">
        <input type="text" id="busca" placeholder="Buscar por nome ou categoria…"
               class="ii-input" style="width:230px;" />
        <div class="d-flex gap-1">
            <button id="btn-lista" class="btn-ii btn-ii-sm" onclick="setView('list')" title="Lista">
                <i class="bi bi-list-ul"></i>
            </button>
            <button id="btn-grade" class="btn-ii btn-ii-sm" onclick="setView('grid')" title="Grade">
                <i class="bi bi-grid-3x3-gap"></i>
            </button>
        </div>
        <a asp-action="Create" class="btn-ii btn-ii-primary btn-ii-sm">
            <i class="bi bi-plus-lg"></i> Novo Produto
        </a>
    </div>
</div>

<!-- ── LISTA ── -->
<div id="view-lista">
    <div class="ii-card p-0">
        <table class="ii-table">
            <thead>
                <tr>
                    <th>Foto</th>
                    <th>Nome</th>
                    <th>Categoria</th>
                    <th>Custo (USD)</th>
                    <th>Margem</th>
                    <th>Preço Final</th>
                    <th>Estoque</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr class="produto-item" data-busca="@p.Nome @p.Categoria.Nome">
                        <td>
                            @if (p.Foto != null)
                            {
                                <img src="@p.Foto" width="40" height="40"
                                     style="object-fit:cover;border-radius:4px;" />
                            }
                        </td>
                        <td>@p.Nome</td>
                        <td>@p.Categoria.Nome</td>
                        <td>$ @p.CustoUsd.ToString("F2")</td>
                        <td>@((p.Margem * 100).ToString("F0"))%</td>
                        <td>R$ @p.PrecoFinal.ToString("F2")</td>
                        <td>@p.Estoque</td>
                        <td>
                            @if (p.Ativo)
                            {
                                <span class="ii-badge ii-badge-green">Ativo</span>
                            }
                            else
                            {
                                <span class="ii-badge ii-badge-gray">Inativo</span>
                            }
                        </td>
                        <td>
                            <div class="d-flex gap-1 flex-wrap">
                                <a asp-action="Edit" asp-route-id="@p.Id"
                                   class="btn-ii btn-ii-ghost btn-ii-sm">Editar</a>
                                @if (p.Ativo)
                                {
                                    <form asp-action="Delete" asp-route-id="@p.Id" method="post" class="d-inline"
                                          onsubmit="return confirm('Desativar este produto?')">
                                        <button type="submit" class="btn-ii btn-ii-warning btn-ii-sm">Desativar</button>
                                    </form>
                                }
                                else
                                {
                                    <form asp-action="Reativar" asp-route-id="@p.Id" method="post" class="d-inline">
                                        <button type="submit" class="btn-ii btn-ii-success btn-ii-sm">Reativar</button>
                                    </form>
                                }
                                <form asp-action="ExcluirPermanente" asp-route-id="@p.Id" method="post" class="d-inline"
                                      onsubmit="return confirm('Excluir permanentemente? Esta ação não pode ser desfeita e removerá também todas as encomendas vinculadas a este produto.')">
                                    <button type="submit" class="btn-ii btn-ii-danger btn-ii-sm">Excluir</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- ── GRADE ── -->
<div id="view-grade">
    <div class="row g-3">
        @foreach (var p in Model)
        {
            <div class="col-sm-6 col-md-4 col-lg-3 produto-item" data-busca="@p.Nome @p.Categoria.Nome">
                <div class="card h-100">
                    @if (p.Foto != null)
                    {
                        <img src="@p.Foto" class="card-img-top" style="height:150px;object-fit:cover;" />
                    }
                    else
                    {
                        <div class="ii-img-placeholder" style="height:140px;border-radius:calc(var(--radius) - 1px) calc(var(--radius) - 1px) 0 0;">
                            Sem foto
                        </div>
                    }
                    <div class="card-body d-flex flex-column" style="padding:1rem;">
                        <div class="d-flex justify-content-between align-items-start gap-2 mb-1">
                            <span class="fw-semibold text-truncate">@p.Nome</span>
                            @if (p.Ativo)
                            {
                                <span class="ii-badge ii-badge-green flex-shrink-0">Ativo</span>
                            }
                            else
                            {
                                <span class="ii-badge ii-badge-gray flex-shrink-0">Inativo</span>
                            }
                        </div>
                        <div class="ii-card-title">@p.Categoria.Nome</div>
                        <div class="d-flex justify-content-between mt-2 mb-3" style="font-size:0.85rem;">
                            <span style="color:var(--primary);font-weight:600;">R$ @p.PrecoFinal.ToString("F2")</span>
                            <span style="color:var(--text-3);">@p.Estoque un.</span>
                        </div>
                        <div class="d-flex gap-1 mt-auto flex-wrap">
                            <a asp-action="Edit" asp-route-id="@p.Id"
                               class="btn-ii btn-ii-ghost btn-ii-sm">Editar</a>
                            @if (p.Ativo)
                            {
                                <form asp-action="Delete" asp-route-id="@p.Id" method="post" class="d-inline"
                                      onsubmit="return confirm('Desativar este produto?')">
                                    <button type="submit" class="btn-ii btn-ii-warning btn-ii-sm">Desativar</button>
                                </form>
                            }
                            else
                            {
                                <form asp-action="Reativar" asp-route-id="@p.Id" method="post" class="d-inline">
                                    <button type="submit" class="btn-ii btn-ii-success btn-ii-sm">Reativar</button>
                                </form>
                            }
                            <form asp-action="ExcluirPermanente" asp-route-id="@p.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('Excluir permanentemente? Esta ação não pode ser desfeita e removerá também todas as encomendas vinculadas a este produto.')">
                                <button type="submit" class="btn-ii btn-ii-danger btn-ii-sm">Excluir</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
<script>
    function setView(v) {
        localStorage.setItem('ii-produtos-view', v);
        document.getElementById('view-lista').style.display = v === 'list' ? '' : 'none';
        document.getElementById('view-grade').style.display = v === 'grid' ? '' : 'none';
        document.getElementById('btn-lista').className = 'btn-ii btn-ii-sm ' + (v === 'list' ? 'btn-ii-primary' : 'btn-ii-ghost');
        document.getElementById('btn-grade').className = 'btn-ii btn-ii-sm ' + (v === 'grid' ? 'btn-ii-primary' : 'btn-ii-ghost');
    }

    setView(localStorage.getItem('ii-produtos-view') || 'list');

    document.getElementById('busca').addEventListener('input', function () {
        const termo = this.value.toLowerCase();
        document.querySelectorAll('.produto-item').forEach(function (el) {
            el.style.display = el.dataset.busca.toLowerCase().includes(termo) ? '' : 'none';
        });
    });
</script>
}
